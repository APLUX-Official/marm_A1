<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>easy_handeye2</name>
  <version>1.0.0</version>
  <description>Hardware-independent hand-eye calibration for ROS2 (C++ implementation)</description>

  <maintainer email="your_email@example.com">Your Name</maintainer>
  <license>LGPLv3</license>
  <author email="your_email@example.com">Your Name</author>

  <buildtool_depend>ament_cmake</buildtool_depend>
  <buildtool_depend>rosidl_default_generators</buildtool_depend>

  <!-- Interface generation -->
  <depend>builtin_interfaces</depend>
  <exec_depend>rosidl_default_runtime</exec_depend>
  <member_of_group>rosidl_interface_packages</member_of_group>

  <!-- Core dependencies -->
  <depend>rclcpp</depend>
  <depend>std_msgs</depend>
  <depend>geometry_msgs</depend>
  <depend>tf2</depend>
  <depend>tf2_ros</depend>
  <depend>tf2_geometry_msgs</depend>

  <!-- OpenCV for calibration algorithms -->
  <build_depend>OpenCV</build_depend>
  <exec_depend>OpenCV</exec_depend>

  <!-- Eigen for matrix operations -->
  <build_depend>eigen</build_depend>

  <!-- YAML-CPP for configuration -->
  <build_depend>yaml-cpp</build_depend>
  <exec_depend>yaml-cpp</exec_depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
